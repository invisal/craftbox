{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": [
      "electron-vite/node"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ],
      "@screen-recorder/*": [
        "src/renderer/tools/screen-recorder/*"
      ]
    }
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "electron.vite.config.ts",
    "src/renderer/tools/screen-recorder/types/**/*"],
  "exclude": [
    // Reference-only source from another product, kept for adapting native
    // recording helpers from -- see src/main/screen-recorder/.gitignore.
    // Not part of this app; imports its own repo's paths that don't exist here.
    "src/main/screen-recorder/native/**",
    "src/main/screen-recorder/native-bridge/**"
  ]
}
