{
  "name": "benpocket",
  "version": "0.0.1",
  "description": "benpocket, a personal multi-purpose desktop toolkit (Swiss Army knife) combining small tools.",
  "main": "./out/main/index.js",
  "author": "https://benpocket.com",
  "homepage": "https://benpocket.com",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/lib-storage": "^3.1088.0",
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fix-webm-duration/fix": "^1.0.1",
    "@homebridge/dbus-native": "^0.7.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "cloudflare": "^7.0.0",
    "cnfast": "^0.0.8",
    "echarts": "^6.1.0",
    "electron-store": "^8.2.0",
    "gif.js": "^0.2.0",
    "lucide-react": "^1.23.0",
    "mediabunny": "^1.50.9",
    "pixi.js": "^8.19.0",
    "uiohook-napi": "^1.5.5",
    "web-demuxer": "^4.0.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/gif.js": "^0.2.5",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "knip": "^6.26.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
